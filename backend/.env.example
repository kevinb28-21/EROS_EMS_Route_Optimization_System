# EROS Backend Configuration
# Copy this file to .env and adjust values as needed

# Database
# Option A: SQLite for local development (no setup required)
DATABASE_URL=sqlite:///./eros.db
# Option B: PostgreSQL (recommended for production / Docker deployment)
# DATABASE_URL=postgresql://eros:eros_dev@localhost:5432/eros_db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Simulation Settings
SIMULATION_ENABLED=true
SIMULATION_INTERVAL_SECONDS=5

# Optional: OSRM server URL (if using external routing)
# OSRM_URL=http://localhost:5000
